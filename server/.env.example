# DataPool Server — Environment Variables
# Copy to .env and fill in values

# Solana RPC (use Helius for production, devnet public for development)
SOLANA_RPC_URL=https://api.devnet.solana.com
# HELIUS_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_KEY

# Keeper keypair (base58 private key — this wallet pays tx fees)
# Generate: solana-keygen new --outfile keeper.json && cat keeper.json
KEEPER_KEYPAIR_PATH=/home/burak/.config/solana/id.json

# DataPool program ID
PROGRAM_ID=62pKxmwZxC7SA4TSYW7FYAxewRU6UXKT2bh7xC55Kg4D

# Data provider API keys (optional — needed for paid DePIN APIs)
# WEATHERXM_API_KEY=
# HIVEMAPPER_API_KEY=

# Server port
PORT=3001
